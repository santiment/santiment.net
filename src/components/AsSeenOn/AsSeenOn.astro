---
import { Image } from 'astro:assets'
import { cn } from 'san-webkit-next/ui/utils'

import binance from './assets/binance.svg'
import bloomberg from './assets/bloomberg.svg'
import ethereum from './assets/ethereum.svg'
import cnn from './assets/cnn.svg'
import coindesk from './assets/coindesk.svg'
import cointelegraph from './assets/cointelegraph.svg'
import nasdaq from './assets/nasdaq.svg'
import ripple from './assets/ripple.svg'
import bitcoinMagazine from './assets/bitcoin-magazine.svg'
import wired from './assets/wired.svg'
import bitfinex from './assets/bitfinex.svg'
import cardano from './assets/cardano.svg'
import kraken from './assets/kraken.svg'
import coinontag from './assets/coinotag.svg'
import kucoin from './assets/kucoin.svg'
import maker from './assets/maker.svg'

type Props = {
  class?: string
}

const { class: className = '' } = Astro.props

const logos = [
  { src: binance, alt: 'Binance' },
  { src: ethereum, alt: 'Ethereum' },
  { src: bloomberg, alt: 'Bloomberg' },
  { src: cnn, alt: 'CNN' },
  { src: coindesk, alt: 'CoinDesk' },
  { src: cointelegraph, alt: 'CoinTelegraph' },
  { src: nasdaq, alt: 'Nasdaq' },
  { src: ripple, alt: 'Ripple' },
  { src: bitcoinMagazine, alt: 'Bitcoin Magazine' },
  { src: wired, alt: 'Wired' },
  { src: bitfinex, alt: 'Bitfinex' },
  { src: cardano, alt: 'Cardano' },
  { src: kraken, alt: 'Kraken' },
  { src: coinontag, alt: 'Coinotag' },
  { src: kucoin, alt: 'KuCoin' },
  { src: maker, alt: 'Maker' },
]
---

<section class={cn('overflow-hidden py-6', className)}>
  <h2 class="mx-auto mb-6 flex items-center gap-2 text-lg text-black">
    <div class="h-[5px] w-[5px] rounded-full bg-black md:h-[3px] md:w-[3px]"></div>
    As seen on
    <div class="h-[5px] w-[5px] rounded-full bg-black md:h-[3px] md:w-[3px]"></div>
  </h2>

  <div class="relative flex w-full overflow-hidden">
    <div class="animate-marquee flex flex-shrink-0 whitespace-nowrap will-change-transform">
      {logos.map(({ src, alt }) => <Image src={src} alt={alt} class="mr-8 h-6 sm:h-4 w-auto" />)}
      {logos.map(({ src, alt }) => <Image src={src} alt="" class="mr-8 h-6 sm:h-4 w-auto" aria-hidden="true" />)}
    </div>
  </div>
</section>
