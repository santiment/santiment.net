---
import Footer from 'san-webkit-next/ui/app/Footer'
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero'
import Intro from '../components/Intro'
import ProvenByNumbers from '../components/ProvenByNumbers'
import AnalyticsOverview from '../components/AnalyticsOverview'
import Tweets from '../components/Tweets'
import FinalCTA from '../components/FinalCTA'
import Nav from '../components/Nav'
import SEO from '../components/SEO.astro'

import desktopIllus from '../components/Hero/assets/illus-desktop.svg'
import laptopIllus from '../components/Hero/assets/illus-laptop.svg'
---

<Layout>
  <SEO slot="seo" />

  <Fragment slot="head">
    <link
      rel="preload"
      href={desktopIllus.src}
      as="image"
      type="image/svg+xml"
      media="(min-width: 1280px)"
      fetchpriority="high"
    />

    <link
      rel="preload"
      href={laptopIllus.src}
      as="image"
      type="image/svg+xml"
      media="(min-width: 993px) and (max-width: 1279px)"
      fetchpriority="high"
    />
  </Fragment>

  <Nav slot="navigation" isAnimated isNightMode />

  <main>
    <Hero />
    <Intro />
    <ProvenByNumbers />
    <AnalyticsOverview />
    <Tweets />
    <FinalCTA />
  </main>

  <Footer class="bg-athens [&>div]:max-w-[1140px]" client:visible />
</Layout>
